@model IEnumerable<HomeServices.Models.Category>
@{
    ViewData["Title"] = "Home Page";
}

<link rel="stylesheet" href="~/css/home.css" />

<section class="hero-section animate__animated animate__fadeIn">
    <div class="container text-center">
        @if (User.Identity.IsAuthenticated && User.IsInRole("ServiceProvider"))
        {
            @* --- واجهة البروفيدر: شريط "الخدمات المطلوبة" نسخة من شريط البحث --- *@
            <h1 class="hero-title animate__animated animate__zoomIn">Welcome back, Master Artisan!</h1>

            <p class="hero-subtitle animate__animated animate__fadeIn animate__delay-1s"
               style="font-weight: 300 !important; line-height: 1.8 !important; max-width: 650px; margin: 0 auto 30px auto; opacity: 0.9;">
                Your expertise is in high demand. Explore new opportunities and start your next mission today.
            </p>

            <div class="mt-5 animate__animated animate__fadeInUp animate__delay-1s">
                @* Container الأبيض اللي بيشبه شريط البحث بالظبط *@
                <div style="max-width: 650px; margin: 0 auto; background: #ffffff; padding: 8px; border-radius: 50px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 15px 35px rgba(0,0,0,0.15); height: 70px;">

                    @* نص توضيحي على الشمال *@
                    <span style="color: #999; padding-left: 30px; font-weight: 300; font-size: 1.1rem; flex-grow: 1; text-align: left;">
                        Explore available missions...
                    </span>

                    @* الزرار الكحلي اللي على اليمين *@
                    <a asp-controller="Provider" asp-action="AvailableRequests"
                       style="background-color: #1a237e !important;
                                  color: #ffffff !important;
                                  display: flex !important;
                                  align-items: center !important;
                                  justify-content: center !important;
                                  padding: 0 40px !important;
                                  border-radius: 50px !important;
                                  font-weight: 600 !important;
                                  font-size: 1.1rem !important;
                                  text-decoration: none !important;
                                  height: 100% !important;
                                  transition: 0.3s !important;
                                  border: none !important;
                                  min-width: 180px !important;">
                        Find Jobs
                    </a>
                </div>
            </div>
        }
        else
        {
            @* --- واجهة الكاستمر: شريط البحث التقليدي --- *@
            <h1 class="hero-title animate__animated animate__zoomIn">Your Home, Mastered</h1>
            <p class="hero-subtitle animate__animated animate__fadeIn animate__delay-1s">
                Connect with the finest local artisans and service professionals who treat your home with the mastery it deserves.
            </p>

            <form asp-controller="Home" asp-action="Index" method="get">
                <div class="search-bar-container animate__animated animate__fadeInUp animate__delay-1s">
                    <input type="text" name="searchString" placeholder="Search for services (e.g. plumbing, cleaning)...">
                    <button type="submit" class="btn-find">Find Artisan</button>
                </div>
            </form>
        }
    </div>
</section>

@if (!(User.Identity.IsAuthenticated && User.IsInRole("ServiceProvider")))
{
    <div class="container my-5">
        <div class="row g-4 text-start">
            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    <div class="col-md-4 scroll-reveal">
                        <div class="service-card shadow-sm" onclick="location.href='@Url.Action("Create", "Requests", new { categoryId = item.Id })'">
                            <img src="~/img/@(string.IsNullOrEmpty(item.Icon) ? "default-user.png" : item.Icon)" style="width:100%; height:250px; object-fit:cover;">
                            <div class="service-card-overlay">
                                <small class="text-uppercase fw-bold text-info">Service</small>
                                <h4 class="fw-bold text-white">@item.Name</h4>
                                <p class="small mb-0 text-white-50">@item.Description</p>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

<section class="py-5 bg-white shadow-sm mt-5">
    <div class="container text-center">
        <div class="row g-4">
            <div class="col-md-4 scroll-reveal">
                <div class="p-3">
                    <i class="fas fa-check-circle fa-2x text-primary mb-3"></i>
                    <h5 class="fw-bold">Quality Guaranteed</h5>
                    <p class="text-muted small">Every artisan is vetted for excellence.</p>
                </div>
            </div>
            <div class="col-md-4 scroll-reveal">
                <div class="p-3">
                    <i class="fas fa-shield-alt fa-2x text-primary mb-3"></i>
                    <h5 class="fw-bold">Secure Payments</h5>
                    <p class="text-muted small">Your transactions are safe and protected.</p>
                </div>
            </div>
            <div class="col-md-4 scroll-reveal">
                <div class="p-3">
                    <i class="fas fa-headset fa-2x text-primary mb-3"></i>
                    <h5 class="fw-bold">24/7 Support</h5>
                    <p class="text-muted small">We're here to help you around the clock.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('animate__animated', 'animate__fadeInUp');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
    </script>
}