@model IEnumerable<HomeServices.Models.Request>

@{
    ViewData["Title"] = "Admin Dashboard";
    var complaints = ViewBag.Complaints as IEnumerable<HomeServices.Models.Complaint>;
}

<div class="container mt-4">
    <h2 class="text-center mb-4">System Management Dashboard</h2>

    <!-- Current Orders Section -->
    <div class="card shadow mb-5">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Current Orders</h4>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Service</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Customer?.UserName</td>
                            <td>@item.Category?.Name</td>
                            <td>@item.CreatedAt.ToShortDateString()</td>
                            <td>
                                <span class="badge @(item.Status == "Accepted" ? "bg-success" : item.Status == "Cancelled by Admin" ? "bg-danger" : "bg-info")">
                                    @item.Status
                                </span>
                            </td>
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <a asp-action="CancelRequest" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Are you sure you want to reject this order?')">
                                        Reject Order
                                    </a>
                                }
                                else if (item.Status == "Cancelled by Admin")
                                {
                                    <span class="badge bg-secondary">Rejected by Admin</span>
                                }
                                else
                                {
                                    <span class="text-muted small">In Progress or Completed</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Complaints & Issues Section -->
    <div class="card shadow">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Complaints & Issues</h4>
        </div>
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Email</th>
                        <th>Title</th>
                        <th>Details</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (complaints != null)
                    {
                        @foreach (var comp in complaints)
                        {
                            <tr>
                                <td>@comp.CreatedAt.ToShortDateString()</td>
                                <td>@comp.UserEmail</td>
                                <td>@comp.Title</td>
                                <td>@comp.Description</td>
                                <td>
                                    <span class="badge @(comp.Status == "Solved" ? "bg-success" : "bg-warning text-dark")">
                                        @(comp.Status == "Solved" ? "Solved" : "Pending")
                                    </span>
                                </td>
                                <td>
                                    @if (comp.Status != "Solved")
                                    {
                                        <a asp-action="ResolveComplaint" asp-route-id="@comp.Id"
                                           class="btn btn-sm btn-success">Mark as Solved</a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>