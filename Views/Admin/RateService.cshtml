@model HomeServices.Models.ServiceReview

@{
    ViewData["Title"] = "Rate Service";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="container mt-5 mb-5">
    <div class="card shadow-lg border-0 mx-auto" style="max-width: 700px; border-radius: 15px;">
        <div class="card-header bg-primary text-white text-center py-4" style="border-radius: 15px 15px 0 0;">
            <h3 class="fw-bold mb-1"><i class="fas fa-star-half-alt me-2"></i>Rate Your Experience</h3>
            <p class="mb-0 opacity-75">Service: @ViewBag.CategoryName | Specialist: @ViewBag.ProviderName</p>
        </div>
        <div class="card-body p-5">
            <form asp-action="RateService" method="post">
                @Html.AntiForgeryToken()

                @* الربط مع الأسماء الجديدة المحدثة في الموديل *@
                <input type="hidden" asp-for="RequestId" />
                <input type="hidden" asp-for="ServiceProviderId" />
                <input type="hidden" asp-for="CustomerId" />

                <div class="text-center mb-5">
                    <label class="h5 d-block fw-bold text-dark mb-3">How would you rate the service?</label>
                    <div class="star-rating">
                        @for (int i = 5; i >= 1; i--)
                        {
                            <input type="radio" id="star@i" asp-for="Rating" value="@i" />
                            <label for="star@i" title="@i stars"><i class="fas fa-star"></i></label>
                        }
                    </div>
                    <span asp-validation-for="Rating" class="text-danger small fw-bold"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Comment" class="h5 fw-bold text-dark mb-2">Your Feedback</label>
                    <textarea asp-for="Comment" class="form-control border-2 shadow-sm" rows="4"
                              style="border-radius: 10px;"
                              placeholder="Describe your experience with the professional..."></textarea>
                    <span asp-validation-for="Comment" class="text-danger small fw-bold"></span>
                </div>

                <hr class="my-4 opacity-25">

                <div class="text-center mt-4 d-grid gap-2 d-md-block">
                    <button type="submit" class="btn btn-success btn-lg px-5 rounded-pill shadow-sm fw-bold me-md-2">
                        <i class="fas fa-paper-plane me-2"></i>Submit Review
                    </button>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary btn-lg px-5 rounded-pill">
                        Later
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
        font-size: 3rem;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            color: #ddd;
            cursor: pointer;
            transition: 0.2s;
            padding: 0 8px;
        }

            .star-rating input:checked ~ label,
            .star-rating label:hover,
            .star-rating label:hover ~ label {
                color: #ffc107;
                transform: scale(1.1);
            }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }
</style>