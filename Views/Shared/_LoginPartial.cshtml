@using Microsoft.AspNetCore.Identity
@using HomeServices.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        var displayName = currentUser?.FullName ?? User.Identity?.Name;

        @if (currentUser != null)
        {
            <li class="nav-item me-2">
                <div class="px-3 py-1 bg-light border rounded-pill d-flex align-items-center shadow-sm" title="Current Wallet Balance">
                    <i class="bi bi-wallet2 text-success me-2"></i>
                    <span class="fw-bold text-dark" style="font-size: 0.9rem;">
                        @currentUser.WalletBalance.ToString("C")
                    </span>
                </div>
            </li>
        

        <li class="nav-item">
            <span class="welcome-text">
                Welcome, <strong class="user-name">@currentUser.FullName</strong>
            </span>
        </li>

        <li class="nav-item">
            <a class="nav-link btn btn-outline-primary mx-2 shadow-sm" asp-controller="Account" asp-action="Profile">My Profile</a>
        </li>

        <li class="nav-item">
            <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="nav-link btn btn-link text-danger">Logout</button>
            </form>
        </li>
        }
        else
        {
            // لو الداتابيز اتمسحت واليوزر بقى null، اعرضي أزرار الدخول فوراً
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Register</a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
            </li>
        }

    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
        </li>
    }
</ul>