@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {

        <li class="nav-item ms-2">
            <form class="d-flex align-items-center m-0 p-0" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="nav-link btn btn-outline-danger btn-sm px-3 rounded-pill border-0 fw-bold">
                    <i class="fas fa-sign-out-alt me-1"></i> Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
           <a class="nav-link btn-nav-register" asp-controller="Account" asp-action="Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link btn-nav-login" asp-controller="Account" asp-action="Login">Login</a>
        </li>
    }
</ul>