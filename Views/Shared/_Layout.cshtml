@using HomeServices.Data
@using System.Security.Claims
@inject ApplicationDbContext _context

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ServicePro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #1a237e;
            --accent: #00bcd4;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8f9fa;
        }

        .navbar {
            background: white !important;
            border-bottom: 1px solid #eee;
            padding: 12px 0;
        }

        .navbar-brand {
            font-weight: 800;
            color: var(--primary) !important;
            font-size: 1.4rem;
        }

        .nav-link {
            font-weight: 600;
            color: #444 !important;
            padding: 0.5rem 12px !important;
        }

            .nav-link:hover {
                color: var(--accent) !important;
            }

        .wallet-pill {
            background: #f1f5f9;
            border-radius: 50px;
            padding: 6px 16px;
            font-weight: 700;
            color: var(--primary);
            border: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-right: 15px;
        }

        .bell-btn {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: #fff;
            border: 1px solid #eee;
            position: relative;
            color: #444;
            margin-right: 15px;
        }

        .unread-dot {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 8px;
            height: 8px;
            background: #ff4757;
            border-radius: 50%;
            border: 2px solid #fff;
        }

        /* تعديل شكل البروفايل ليحتوي على الصورة */
        .profile-link {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            padding: 5px 15px;
            border-radius: 12px;
            transition: 0.3s;
            background: transparent;
            color: var(--primary) !important;
            font-weight: 700;
        }

            .profile-link:hover {
                background: #f8f9fa;
            }

        .nav-profile-img {
            width: 38px;
            height: 38px;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid var(--primary);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-bolt text-info me-2"></i>ServicePro
                </a>

                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto ms-4">
                        @if (User.Identity.IsAuthenticated)
                        {
                            if (User.IsInRole("Customer"))
                            {
                                <li class="nav-item"><a class="nav-link text-info" asp-controller="Requests" asp-action="Index">My Requests</a></li>
                            }
                            if (User.IsInRole("ServiceProvider"))
                            {
                                <li class="nav-item"><a class="nav-link text-primary" asp-controller="Provider" asp-action="Dashboard">Dashboard</a></li>
                            }
                        }
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="SendComplaint">Complaints</a></li>
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                            var hasUnread = _context.Notifications.Any(n => n.UserId == userId && !n.IsRead);
                            var user = _context.Users.Find(userId);

                            <a class="bell-btn" asp-controller="Notifications" asp-action="Index">
                                <i class="far fa-bell fa-lg"></i>
                                @if (hasUnread)
                                {
                                    <span class="unread-dot"></span>
                                }
                            </a>

                            <div class="wallet-pill d-none d-md-flex">
                                <i class="fas fa-wallet opacity-50"></i>
                                <span>@user?.WalletBalance.ToString("C")</span>
                            </div>

                            @* التعديل هنا: استبدال زرار البروفايل بصورة المستخدم *@
                            <a class="profile-link shadow-sm" asp-controller="Account" asp-action="Profile">
                                @if (user != null && !string.IsNullOrEmpty(user.ProfilePicture))
                                {
                                    <img src="~/img/@user.ProfilePicture" class="nav-profile-img" alt="Profile" />
                                }
                                else
                                {
                                    <i class="fas fa-user-circle fa-2xl"></i>
                                }
                                <span class="d-none d-lg-inline">@user?.FullName</span>
                            </a>
                        }

                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="py-4">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>