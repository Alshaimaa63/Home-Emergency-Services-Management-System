@using HomeServices.Data
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@inject ApplicationDbContext _context
@inject UserManager<HomeServices.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ServicePro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --primary: #1a237e;
            --accent: #00bcd4;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8f9fa;
        }

        .navbar {
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            flex-grow: 1; 
            margin: 0 auto;
            
        }
        
        .navbar-collapse {
            display: flex !important;
            justify-content: flex-end !important; 
            align-items: center !important;
            width: 100%;
        }

        .navbar-nav {
            display: flex !important;
            flex-direction: row !important;
            justify-content: center !important;
            align-items: center !important;
            flex-grow: unset !important; 
            margin: 0 auto !important;
            gap: 30px !important;
        }

        .navbar-nav .nav-item {
            display: flex !important;
            align-items: center !important;
        }

        .navbar-brand {
            font-weight: 800;
            color: var(--primary) !important;
            font-size: 1.4rem;
        }

        .nav-link {
            font-weight: 600;
            color: var(--primary) !important;
            padding: 0.5rem 12px !important;
            transition: all 0.3s ease;
        }

        .nav-link:hover {
            color: var(--accent) !important;
            transform: translateY(-2px);
        }

        .bell-btn {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: #fff;
            border: 1px solid #eee;
            position: relative;
            color: #444;
            margin-right: 15px;
            transition: all 0.3s ease;   
        }

        .unread-dot {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 8px;
            height: 8px;
            background: #ff4757;
            border-radius: 50%;
            border: 2px solid #fff;
        }

        .bell-btn:hover {
            background-color: #f1f5f9;
            color: var(--accent);    
            border-color: var(--accent); 
            transform: translateY(-2px); 
        }

        .wallet-pill {
            background: #f1f5f9;
            border-radius: 50px;
            padding: 6px 16px;
            font-weight: 700;
            color: var(--primary);
            border: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-right: 15px;
        }

        .profile-link {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            padding: 5px 15px;
            border-radius: 12px;
            border: 1px solid transparent;
            background: transparent;
            color: var(--primary) !important;
            font-weight: 700;
            transition: all 0.3s ease;
        }

        .profile-link:hover {
            background-color: #f1f5f9; 
            color: var(--accent) !important; 
            /* border-color: var(--accent); */
            transform: translateY(-2px); 
        }

        .nav-profile-img {
            width: 38px;
            height: 38px;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid var(--primary);
        }

       .profile-link:hover .nav-profile-img {
            border-color: var(--accent);
       }

       .btn-nav-register {
            font-weight: 700 !important;
            padding: 0 20px !important; /* صفرنا الـ padding العمودي واعتمدنا على الـ height */
            border-radius: 50px !important;
            color: var(--primary) !important;
            border: 1px solid var(--primary) !important;
            background-color: transparent !important;
            transition: all 0.3s ease !important;
            margin-right: 8px !important;
    
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            line-height: 1 !important; 
            height: 38px !important; /* ارتفاع ثابت ومثالي متناسق مع جرس الإشعارات */
            width: auto !important; /* إجبار الزرار ألا ينفجر بكامل العرض */
            box-sizing: border-box !important;
        }

        /* زر تسجيل الدخول في النافبار */
        .btn-nav-login {
            font-weight: 700 !important;
            padding: 0 20px !important;
            border-radius: 50px !important;
            background-color: var(--primary) !important;
            color: white !important;
            border: 1px solid var(--primary) !important;
            transition: all 0.3s ease !important;
            margin-right: 0 !important;
    
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            line-height: 1 !important;
            height: 38px !important; /* نفس الارتفاع بالظبط */
            width: auto !important; /* إجبار الزرار ألا ينفجر بكامل العرض */
            box-sizing: border-box !important;
        }

        /* الـ Hover السلس والموحد */
        .btn-nav-register:hover,
        .btn-nav-login:hover {
       background-color: transparent !important;
    border-color: var(--accent) !important;
    color: var(--accent) !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0, 188, 212, 0.15);
    }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg sticky-top shadow-sm">
            <div class="container">
                
                @* change the admin logo *@
                <a class="navbar-brand" asp-controller="@(User.IsInRole("Admin") ? "Admin" : "Home")" asp-action="@(User.IsInRole("Admin") ? "Dashboard" : "Index")">
                    <i class="fas fa-bolt text-info me-2"></i>
                    @(User.IsInRole("Admin") ? "ServicePro Admin Dashboard" : "ServicePro")
                </a>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @* for user who not admin *@
                            if (!User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-bold" asp-controller="Home" asp-action="Index">Home</a>
                                </li>

                                if (User.IsInRole("ServiceProvider"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-info fw-bold" asp-controller="Provider" asp-action="Dashboard">Dashboard</a>
                                    </li>
                                }

                                if (User.IsInRole("Customer"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link fw-bold" asp-controller="Requests" asp-action="Index">History</a>
                                    </li>
                                }

                                <li class="nav-item">
                                    <a class="nav-link fw-bold" asp-controller="Admin" asp-action="SendComplaint">Complaints</a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            var currentUser = await UserManager.GetUserAsync(User);
                            var currentBalance = currentUser?.WalletBalance ?? 0;
                            var userId = currentUser?.Id;

                            @if (!User.IsInRole("Admin"))
                            {
                                @* 1. the notifications *@
                                var hasUnread = _context.Notifications.Any(n => n.UserId == userId && !n.IsRead);
                                <a class="bell-btn" asp-controller="Notifications" asp-action="Index">
                                    <i class="far fa-bell fa-lg"></i>
                                    @if (hasUnread)
                                    {
                                        <span class="unread-dot"></span>
                                    }
                                </a>

                                @* 2. the wallet *@
                                <div class="wallet-pill d-none d-md-flex">
                                    <i class="fas fa-wallet opacity-50"></i>
                                    <span>@currentBalance.ToString("0.00") EGP</span>
                                </div>

                                @* 3. the profile *@
                                <a class="profile-link shadow-sm" asp-controller="Account" asp-action="Profile">
                                    @if (currentUser != null && !string.IsNullOrEmpty(currentUser.ProfilePicture))
                                    {
                                        <img src="~/img/@currentUser.ProfilePicture" class="nav-profile-img" alt="Profile" />
                                    }
                                    else
                                    {
                                        <i class="fas fa-user-circle fa-2xl"></i>
                                    }
                                    <span class="d-none d-lg-inline ms-1">@currentUser?.FullName</span>
                                </a>
                            }
                        }

                        @* the login, register, logout btns *@
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="py-4">
        @RenderBody()
    </main>

    <footer class="bg-white border-top py-4 mt-auto">
        <div class="container text-center text-muted small">
            &copy; 2026 ServicePro Admin Panel. All Rights Reserved.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>