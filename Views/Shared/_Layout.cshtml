<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ServicePro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .navbar { background: #fff !important; border-bottom: 1px solid #eee; }
        .navbar-brand { font-weight: 800; color: #1a237e !important; }
        .nav-link { font-weight: 600; color: #1a1a1a !important; margin: 0 10px; }
        .nav-link:hover { color: #00bcd4 !important; }
        .wallet-nav { background: #f8f9fa; border-radius: 50px; padding: 5px 15px; border: 1px solid #e0e0e0; display: flex; align-items: center; gap: 8px; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">ServicePro</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Customer"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Requests" asp-action="Index">History</a></li>
                            }
                            @if (User.IsInRole("ServiceProvider"))
                            {
                                <li class="nav-item"><a class="nav-link text-primary fw-bold" asp-controller="Provider" asp-action="Dashboard">DashBoard</a></li>
                            }
                        }

                        @if (User.Identity.IsAuthenticated && (User.Identity.Name == "admin@home.com" || User.Identity.Name == "manager@home.com" || User.Identity.Name == "rawanarby11@gmail.com"))
                        {
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a></li>
                        }
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Admin" asp-action="SendComplaint">Complaints</a></li>
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a class="nav-link position-relative me-3 p-0" asp-controller="Notifications" asp-action="Index" title="Notifications">
                                <i class="fas fa-bell fa-lg text-dark"></i>
                                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
                            </a>
                        }
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        <div class="container mt-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0 small">&copy; 2026 ServicePro - Premium Home Care.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>