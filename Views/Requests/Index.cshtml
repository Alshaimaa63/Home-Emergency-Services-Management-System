@model IEnumerable<HomeServices.Models.Request>
@{
    ViewData["Title"] = "Service History";
}


<link rel="stylesheet" href="~/css/history.css?v=1.3" />

<div class="history-bg py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5 animate__animated animate__fadeIn">
            <div>
                <h1 class="fw-bold mb-1" style="color: #1a237e;">Service History</h1>
                <p class="text-muted mb-0">Review your past maintenance records and track ongoing services.</p>
            </div>
            <a asp-controller="Requests" asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="fas fa-plus me-2"></i>New Request
            </a>
        </div>

        <div class="row g-4 mb-5 animate__animated animate__fadeInUp">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 h-100 position-relative custom-stat-card">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div class="card-icon-wrap completed-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <span class="badge bg-soft-success rounded-pill px-2 py-1 small">+2 this month</span>
            </div>
            <div class="mt-auto">
                <h1 class="fw-bold text-dark display-5 mb-1">@ViewBag.CompletedCount.ToString("00")</h1>
                <h6 class="text-muted fw-bold small text-uppercase tracking-wider m-0">Completed Jobs</h6>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 h-100 position-relative custom-stat-card">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div class="card-icon-wrap progress-icon">
                    <i class="span-icon fas fa-clipboard-list"></i>
                </div>
                <span class="badge bg-soft-primary rounded-pill px-3 py-1 small">Active</span>
            </div>
            <div class="mt-auto">
                <h1 class="fw-bold text-dark display-5 mb-1">@ViewBag.InProgressCount.ToString("00")</h1>
                <h6 class="text-muted fw-bold small text-uppercase tracking-wider m-0">In Progress</h6>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-4 h-100 text-white position-relative total-investment-card" style="background-color: #1a237e;">
            <div class="card-watermark">
                <i class="fas fa-wallet"></i>
            </div>
            
            <div class="mb-2">
                <h6 class="text-white-50 text-uppercase small tracking-wider m-0" style="font-weight: 600;">Total Investment</h6>
            </div>
            
            <div class="my-2">
                <h1 class="fw-bold display-4 mb-3">$@(Model.Sum(r => r.FinalPrice ?? 0).ToString("N2"))</h1>
            </div>

                <div class="mt-auto d-flex align-items-center gap-2 pt-2 border-top border-white-10">
                    <div class="avatar-group d-flex align-items-center">
                        <span class="avatar-sm rounded-circle bg-warning text-dark fw-bold d-flex align-items-center justify-content-center border border-2 border-primary" style="width:28px; height:28px; font-size:10px;">👨‍🔧</span>
                        <span class="avatar-sm rounded-circle bg-info text-white fw-bold d-flex align-items-center justify-content-center border border-2 border-primary" style="width:28px; height:28px; font-size:10px; margin-left: -8px;">👩‍💻</span>
                        <span class="avatar-sm rounded-circle bg-success text-white fw-bold d-flex align-items-center justify-content-center border border-2 border-primary" style="width:28px; height:28px; font-size:10px; margin-left: -8px;">👨‍🎨</span>
                    </div>
                    <span class="small text-white-50">Trusted by 12 Master Pros</span>
                </div>
            </div>
        </div>
    </div>

        <div class="card border-0 shadow-lg animate__animated animate__fadeInUp animate__delay-1s" style="border-radius: 20px;">
            <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center">
                <h4 class="fw-bold mb-0 text-dark">
                    <i class="fas fa-history me-2 text-primary"></i>Recent Service Activity
                </h4>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Service & Provider</th>
                                <th>Date</th>
                                <th>Service</th>
                                <th>Status</th>
                                <th>Cost</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                @* إضافة الكلاس و الـ Data URL لجعل السطر قابل للضغط *@
                                <tr class="clickable-row" data-url="@Url.Action("Details", "Requests", new { id = item.Id })" style="cursor: pointer;">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-3">
                                                @(item.Provider?.FullName?.Substring(0, 1) ?? "A")
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@(item.Provider?.FullName ?? "Assigning...")</div>
                                                <div class="text-muted small">Specialist</div>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="text-muted">
                                        @item.CreatedAt.ToString("MMM dd, yyyy")
                                    </td>

                                    <td>
                                        <span class="badge bg-light text-dark border rounded-pill px-3 py-2 fw-medium">
                                            @item.Category.Name
                                        </span>
                                    </td>

                                    <td>
                                        @{
                                            var statusClass = item.Status == "Completed" ? "status-completed" : "status-pending";
                                        }
                                        <div class="badge-ui @statusClass">
                                            <span class="status-dot"></span>
                                            @item.Status
                                        </div>
                                    </td>

                                    <td class="fw-bold text-dark">
                                        @(item.FinalPrice.HasValue ? $"${item.FinalPrice.Value:N2}" : "--")
                                    </td>

                                    @* نستخدم stopPropagation لمنع تداخل الضغطات *@
                                    <td class="text-end" onclick="event.stopPropagation();">
                                        <div class="dropdown">
                                            <button class="btn-action-circle no-border" type="button" data-bs-toggle="dropdown">
                                                <i class="fas fa-ellipsis-v"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                <li>
                                                    <a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id">
                                                        <i class="far fa-eye me-2 text-primary"></i> View Details
                                                    </a>
                                                </li>
                                                @if (item.Status != "Completed" && item.Status == "Pending")
                                                {
                                                    <li>
                                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id">
                                                            <i class="far fa-edit me-2 text-warning"></i> Edit Request
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        $(document).ready(function () {
            $(".clickable-row").click(function () {
                window.location = $(this).data("url");
            });
        });
    </script>
}