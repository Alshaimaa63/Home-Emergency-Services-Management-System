@model IEnumerable<HomeServices.Models.Request>

@{
    ViewData["Title"] = "My Requests";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>My Service Requests</h2>
        <a asp-action="Create" class="btn btn-success">Request New Service</a>
    </div>

    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Service</th>
                <th>Description</th>
                <th>Schedule</th>
                <th>Status</th>
                <th>Provider</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Category.Name</td>
                    <td>@item.Description</td>
                    <td>@item.PreferredSchedule.ToString("g")</td>
                    <td>
                        <span class="badge @(item.Status == "Pending" ? "bg-warning" : "bg-info")">
                            @item.Status
                        </span>
                    </td>
                    <td>@(item.Provider?.FullName ?? "Searching...")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>