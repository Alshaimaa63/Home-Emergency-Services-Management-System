@model HomeServices.Models.Request

@{
    ViewData["Title"] = "Create New Request";
}

<div class="container mt-4">
    <h2>Request a Home Service</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="CategoryId" class="control-label">Service Type</label>
                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                        <option value="">-- Select Service --</option>
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="control-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="PreferredSchedule" class="control-label"></label>
                    <input asp-for="PreferredSchedule" class="form-control" type="datetime-local" />
                    <span asp-validation-for="PreferredSchedule" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Submit Request</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>