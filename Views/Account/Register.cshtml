@model HomeServices.ViewModels.RegisterVM
@{
    ViewData["Title"] = "Create New Account";
}

<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-wrapper py-5">
    <div class="auth-card animate__animated animate__fadeIn" style="max-width: 850px;">
        <div class="text-center mb-4">
            <h1 class="auth-title">Create New Account</h1>
            <p class="auth-subtitle">Join ServicePro Services to manage your professional home care.</p>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            
            <div class="row">
                <!-- Full Name -->
                <div class="col-md-6 mb-3">
                    <label class="input-label">Full Name</label>
                    <div class="custom-input-group">
                        <i class="fas fa-user"></i>
                        <input asp-for="FullName" class="custom-control" placeholder="Enter your full name" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <!-- Email -->
                <div class="col-md-6 mb-3">
                    <label class="input-label">Email Address</label>
                    <div class="custom-input-group">
                        <i class="fas fa-envelope"></i>
                        <input asp-for="Email" class="custom-control" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <!-- Phone Number -->
                <div class="col-md-6 mb-3">
                    <label class="input-label">Phone Number</label>
                    <div class="custom-input-group">
                        <i class="fas fa-phone"></i>
                        <input asp-for="PhoneNumber" class="custom-control" placeholder="01xxxxxxxxx" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <!-- Account Type -->
                <div class="col-md-6 mb-3">
                    <label class="input-label">Account Type</label>
                    <div class="custom-input-group">
                        <i class="fas fa-users-cog"></i>
                        <select asp-for="Role" class="custom-control form-select" style="padding-left: 55px;">
                            <option value="" disabled selected>Select Account Type</option>
                            <option value="Customer">Customer</option>
                            <option value="ServiceProvider">Service Provider</option>
                        </select>
                    </div>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <!-- Address -->
                <div class="col-12 mb-3">
                    <label class="input-label">Address</label>
                    <div class="custom-input-group">
                        <i class="fas fa-map-marker-alt"></i>
                        <input asp-for="Address" class="custom-control" placeholder="Street, Building, City" />
                    </div>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <!-- Password -->
                <div class="col-md-6 mb-3">
                    <label class="input-label">Password</label>
                    <div class="custom-input-group">
                        <i class="fas fa-lock"></i>
                        <input asp-for="Password" type="password" id="regPass" class="custom-control" placeholder="••••••••" />
                        <i class="fas fa-eye pass-toggle" id="toggleRegPass"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <!-- Confirm Password -->
                <div class="col-md-6 mb-4">
                    <label class="input-label">Confirm Password</label>
                    <div class="custom-input-group">
                        <i class="fas fa-check-double"></i>
                        <input asp-for="ConfirmPassword" type="password" class="custom-control" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <button type="submit" class="btn-login py-3">
                Register Now <i class="fas fa-arrow-right ms-2"></i>
            </button>
        </form>

        <div class="text-center mt-4">
            <p class="create-account-text">Already have an account? <a asp-action="Login">Login</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const toggleRegPass = document.querySelector('#toggleRegPass');
        const regPass = document.querySelector('#regPass');
        
        toggleRegPass.addEventListener('click', function () {
            const type = regPass.getAttribute('type') === 'password' ? 'text' : 'password';
            regPass.setAttribute('type', type);
            this.classList.toggle('fa-eye-slash');
        });
    </script>
}
