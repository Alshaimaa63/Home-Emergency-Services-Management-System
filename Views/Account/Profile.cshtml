@model HomeServices.Models.ApplicationUser

@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Personal Profile</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 text-center border-end">
                    <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=random&size=150"
                         class="rounded-circle mb-3" />
                    <h4>@Model.FullName</h4>
                    <span class="badge bg-primary">@ViewBag.UserRole</span>
                </div>
                <div class="col-md-8 px-4">
                    <h5 class="text-muted border-bottom pb-2">User Information</h5>
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Phone:</strong> @(Model.PhoneNumber ?? "Not Set")</p>
                    <p><strong>Address:</strong> @Model.Address</p>
                    <p><strong>Member Since:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                    <div class="mt-4">
                        <a href="/" class="btn btn-secondary">Back to Home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>