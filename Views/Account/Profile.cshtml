@model HomeServices.Models.ApplicationUser
@using System.Security.Claims

@{
    ViewData["Title"] = "Professional Profile";
    var walletColor = Model.WalletBalance > 0 ? "text-success" : "text-dark";
    bool isProvider = ViewBag.UserRole == "ServiceProvider";

    // جلب الـ ID بتاع اليوزر اللي فاتح المتصفح حالياً
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);

    // حسابات التقييم الديناميكية
    var reviewsCount = Model.ReviewsReceived?.Count() ?? 0;
    var avgRating = reviewsCount > 0 ? Model.ReviewsReceived.Average(r => r.Rating) : 0;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="container mt-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 border-0 border-start border-4 border-success" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow border-0" style="border-radius: 15px; overflow: hidden; background-color: #fcfcfc;">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-person-badge me-2"></i>Personal Profile</h4>

            <div class="d-flex align-items-center gap-3">
                @if (Model.Id == currentUserId)
                {
                    <a asp-action="EditProfile" asp-controller="Account" class="btn btn-sm btn-outline-light rounded-pill px-3 shadow-sm">
                        <i class="bi bi-pencil-square me-1"></i> Edit Info
                    </a>
                    <span class="badge bg-success fs-6 shadow-sm">Balance: @Model.WalletBalance.ToString("0.00") EGP</span>
                }
            </div>
        </div>

        <div class="card-body p-4 p-md-5">
            <div class="row">
                <div class="col-md-4 text-center border-md-end mb-4 mb-md-0 pe-md-4">
                    <div class="position-relative d-inline-block mb-3">
                        @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                        {
                            <img src="~/img/@Model.ProfilePicture"
                                 class="rounded-circle shadow border border-4 border-white"
                                 style="width: 160px; height: 160px; object-fit: cover;"
                                 alt="Profile Picture" />
                        }
                        else
                        {
                            <img src="~/img/default-user.png"
                                 class="rounded-circle shadow border border-4 border-white"
                                 style="width: 160px; height: 160px; object-fit: cover;"
                                 onerror="this.src='https://ui-avatars.com/api/?name=@Model.FullName&background=1a237e&color=fff&size=160'"
                                 alt="Default Avatar" />
                        }

                        @if (isProvider)
                        {
                            <span class="position-absolute bottom-0 end-0 bg-success border border-white border-2 rounded-circle p-2 shadow-sm" title="Verified Pro">
                                <i class="fas fa-check text-white"></i>
                            </span>
                        }
                    </div>

                    <h3 class="fw-bold text-dark mb-1">@Model.FullName</h3>

                    @if (isProvider)
                    {
                        <h6 class="text-primary fw-bold mb-3">
                            <i class="fas fa-tools me-1"></i> @(Model.Specialty ?? "Professional Specialist")
                        </h6>

                        <div class="mt-2">
                            <div class="d-inline-block bg-white px-4 py-2 rounded-pill shadow-sm border">
                                <div class="star-rating h5 mb-0">
                                    @if (reviewsCount > 0)
                                    {
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="@(i <= Math.Round(avgRating) ? "fas fa-star text-warning" : "far fa-star text-secondary")"></i>
                                        }
                                        <span class="ms-2 fw-bold text-dark">@avgRating.ToString("F1")</span>
                                        <div class="small text-muted mt-1" style="font-size: 0.8rem;">(@reviewsCount Reviews)</div>
                                    }
                                    else
                                    {
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="far fa-star text-secondary"></i>
                                        }
                                        <div class="small text-muted mt-1">No ratings yet</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <span class="badge bg-secondary px-4 py-2 mt-2 shadow-sm rounded-pill">Customer</span>
                    }
                </div>

                <div class="col-md-8 ps-md-5">
                    @if (isProvider)
                    {
                        <div class="p-4 bg-white rounded-4 shadow-sm mb-4 position-relative" style="border-left: 5px solid #0d6efd;">
                            <i class="fas fa-quote-left fa-2x text-primary opacity-25 position-absolute top-0 start-0 ms-3 mt-3"></i>
                            <h5 class="text-dark fw-bold mb-3 position-relative z-1" style="padding-left: 2rem;">About Me</h5>
                            <p class="text-muted lh-lg mb-0 position-relative z-1" style="font-size: 1.1rem; padding-left: 2rem; white-space: pre-line;">
                                @(string.IsNullOrWhiteSpace(Model.Bio) ? "Professional service provider ready to help!" : Model.Bio)
                            </p>
                        </div>
                    }

                    <h5 class="text-muted border-bottom pb-2 mb-4 mt-2">User Information</h5>
                    <div class="row g-4 bg-white p-4 rounded-4 shadow-sm m-0">
                        <div class="col-sm-6">
                            <label class="small text-muted fw-bold text-uppercase">Email</label>
                            <p class="text-dark fw-medium mt-1 mb-0"><i class="bi bi-envelope me-2 text-primary"></i>@Model.Email</p>
                        </div>
                        <div class="col-sm-6">
                            <label class="small text-muted fw-bold text-uppercase">Phone</label>
                            <p class="text-dark fw-medium mt-1 mb-0"><i class="bi bi-phone me-2 text-primary"></i>@(Model.PhoneNumber ?? "Not Set")</p>
                        </div>
                        <div class="col-sm-6 mt-4">
                            <label class="small text-muted fw-bold text-uppercase">Address</label>
                            <p class="text-dark fw-medium mt-1 mb-0"><i class="bi bi-geo-alt me-2 text-primary"></i>@Model.Address</p>
                        </div>
                        <div class="col-sm-6 mt-4">
                            <label class="small text-muted fw-bold text-uppercase">Joined</label>
                            <p class="text-dark fw-medium mt-1 mb-0"><i class="bi bi-calendar-check me-2 text-primary"></i>@Model.CreatedAt.ToString("MMM yyyy")</p>
                        </div>
                    </div>
                </div>
            </div>

            @if (isProvider && reviewsCount > 0)
            {
                <hr class="my-5 opacity-10" />
                <div class="row px-3">
                    <h4 class="fw-bold text-dark mb-4 text-center">What Customers Say</h4>
                    <div class="row g-4">
                        @foreach (var review in Model.ReviewsReceived.OrderByDescending(r => r.CreatedAt))
                        {
                            <div class="col-md-6">
                                @* 🔥 جعل كارت التقييم بالكامل رابطاً يودي لتفاصيل الطلب 🔥 *@
                                <a asp-controller="Requests" asp-action="Details" asp-route-id="@review.RequestId" class="text-decoration-none">
                                    <div class="card h-100 border-0 bg-white shadow-sm hover-card rounded-4">
                                        <div class="card-body p-4">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center fw-bold me-3 shadow-sm" style="width:45px; height:45px;">
                                                        @(review.Customer?.FullName?.Substring(0, 1) ?? "U")
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0 fw-bold text-dark">@review.Customer?.FullName</h6>
                                                        <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                                                    </div>
                                                </div>
                                                <div class="text-warning bg-light px-2 py-1 rounded-pill">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        <i class="@(i <= review.Rating ? "fas fa-star" : "far fa-star text-secondary")"></i>
                                                    }
                                                </div>
                                            </div>
                                            <p class="card-text text-secondary fst-italic lh-lg mt-2">"@review.Comment"</p>

                                            @* إظهار رقم الطلب بشكل خافت في الأسفل *@
                                            <div class="text-end mt-2">
                                                <span class="badge bg-light text-muted fw-normal" style="font-size: 0.7rem;">Order #@review.RequestId</span>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .text-warning {
        color: #ffc107 !important;
    }

    .text-secondary {
        color: #6c757d !important;
    }

    .hover-card {
        transition: all 0.3s ease;
        border: 1px solid #f8f9fa;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
            border-color: #0d6efd; /* تغيير لون الحدود للأزرق عند الوقوف عليه */
        }

    .border-md-end {
        border-right: 1px solid #eee;
    }

    @@media (max-width: 768px) {
        .border-md-end {
            border-right: none;
            border-bottom: 1px solid #eee;
            padding-bottom: 2rem;
        }
    }
</style>