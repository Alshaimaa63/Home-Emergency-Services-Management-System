@model IEnumerable<HomeServices.Models.Request>

<div class="container mt-4">
    <h2 class="mb-4">Available Service Requests</h2>
    <div class="row">
        @if (!Model.Any())
        {
            <div class="alert alert-info">No new requests available at the moment.</div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-primary">@item.Category?.Name</h5>
                            <p class="card-text">@item.Description</p>
                            <p class="text-muted small mt-auto">Requested on: @item.CreatedAt.ToShortDateString()</p>

                            <form asp-action="AcceptRequest" method="post" class="mt-2">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-success w-100">Accept Request</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>