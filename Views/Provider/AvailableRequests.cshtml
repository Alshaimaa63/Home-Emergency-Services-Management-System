@model IEnumerable<HomeServices.Models.Request>
@{
    ViewData["Title"] = "Available Jobs";
}
<link rel="stylesheet" href="~/css/history.css" />

<style>
    /* 1. إلغاء القيد الـ 100px القديم وإعطاء العمود مساحة مريحة للزرار */
    .table th:last-child, .table td:last-child {
        width: 160px !important; /* مساحة كافية جداً لفرد الزرار */
        text-align: right !important;
        vertical-align: middle !important;
    }

    /* 2. تنسيق إضافي لضمان ثبات النص جوه الزرار على سطر واحد وعدم انكساره */
    .table td .btn {
        white-space: nowrap !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }
</style>

<div class="history-bg">
    <div class="container">
        <div class="mb-5">
            <h2 class="fw-bold" style="color: #1a237e;">Available Jobs</h2>
            <p class="text-muted">The following requests are currently waiting for a service provider. View details to send your price offer.</p>
        </div>

        <div class="custom-table-container shadow-sm border rounded">
            <table class="table mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Request Info</th>
                        <th>Service Type</th>
                        <th>Date Posted</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">Request #@item.Id.ToString("D5")</div>
                                <div class="text-muted small text-truncate" style="max-width: 250px;">@item.Description</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border rounded-pill px-3 py-2">@item.Category?.Name</span>
                            </td>
                            <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end pe-4">
                                
                                <a asp-controller="Requests" asp-action="Details" asp-route-id="@item.Id" 
                                   class="btn btn-sm rounded-pill px-4 shadow-sm text-white" 
                                   style="background-color: var(--primary); border-color: var(--primary);">
                                    View & Offer 
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fas fa-search fa-3x mb-3 d-block opacity-25"></i>
                                No available requests at the moment.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>