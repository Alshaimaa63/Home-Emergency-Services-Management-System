@model IEnumerable<HomeServices.Models.Request>
@{
    ViewData["Title"] = "Available Jobs";
}
<link rel="stylesheet" href="~/css/history.css" />

<div class="history-bg">
    <div class="container">
        <div class="mb-5">
            <h2 class="fw-bold" style="color: #1a237e;">Available Jobs</h2>
            <p class="text-muted">The following requests are currently waiting for a service provider.</p>
        </div>

        <div class="custom-table-container">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Request Info</th>
                        <th>Service Type</th>
                        <th>Date Posted</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">Request #@item.Id</div>
                                <div class="text-muted small">@item.Description</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border rounded-pill px-3 py-2">@item.Category.Name</span>
                            </td>
                            <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end pe-4">
                                <form asp-action="AcceptRequest" method="post">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-success btn-sm rounded-pill px-4">
                                        Accept <i class="fas fa-check ms-1"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>