@model IEnumerable<HomeServices.Models.Request>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Pro Dashboard";
    var currentUser = await UserManager.GetUserAsync(User);
}

<link rel="stylesheet" href="~/css/history.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="history-bg py-5">
    <div class="container">

        @if (currentUser != null && !currentUser.IsVerified)
        {
            <div class="alert alert-warning border-0 shadow-sm mb-4 animate__animated animate__pulse animate__infinite" style="border-left: 5px solid #ffc107 !important; border-radius: 12px;">
                <div class="d-flex align-items-center">
                    <i class="fas fa-clock fa-2x me-3 opacity-75"></i>
                    <div>
                        <h5 class="fw-bold mb-1">Account Under Review</h5>
                        <p class="mb-0 small">Your profile is currently being verified by our team. You will be able to submit offers once the admin approves your account.</p>
                    </div>
                </div>
            </div>
        }

        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h1 class="fw-bold mb-1" style="color: #1a237e;">Pro Dashboard</h1>
                <p class="text-muted mb-0">Welcome back, <strong>@currentUser?.FullName</strong>! Here's your performance overview.</p>
            </div>

            @if (currentUser != null && currentUser.IsVerified)
            {
                <a asp-action="AvailableRequests" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="fas fa-search me-2"></i>Find New Jobs
                </a>
            }
        </div>

        @* --- قسم الإحصائيات --- *@
        <div class="row g-4 mb-5 text-center">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 h-100" style="border-bottom: 4px solid #1a237e !important; border-radius: 15px;">
                    <i class="fas fa-wallet fa-2x text-primary mb-3"></i>
                    <h6 class="text-muted fw-bold small uppercase">Total Earnings</h6>
                    <h2 class="fw-bold text-dark">@(ViewBag.TotalEarnings ?? "0.00") EGP</h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 h-100" style="border-bottom: 4px solid #198754 !important; border-radius: 15px;">
                    <i class="fas fa-check-double fa-2x text-success mb-3"></i>
                    <h6 class="text-muted fw-bold small uppercase">Jobs Completed</h6>
                    <h2 class="fw-bold text-dark">@(Model != null ? Model.Count(r => r.Status == "Completed" || r.Status == "Finished") : 0)</h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 h-100" style="border-left: 4px solid #ffc107 !important; border-radius: 15px;">
                    <i class="fas fa-star fa-2x text-warning mb-3"></i>
                    <h6 class="text-muted fw-bold small uppercase">Reputation Score</h6>
                    <h2 class="fw-bold text-dark">@(currentUser?.IsVerified == true ? "Verified Pro" : "New Member")</h2>
                </div>
            </div>
        </div>

        @* --- جدول المهام --- *@
        <div class="card border-0 shadow-lg" style="border-radius: 20px;">
            <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center">
                <h4 class="fw-bold mb-0 text-dark"><i class="fas fa-briefcase me-2 text-primary"></i>My Recent Tasks</h4>
                <a asp-action="History" class="text-decoration-none fw-bold">View Full History <i class="fas fa-arrow-right ms-1"></i></a>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="py-3">Service & Client</th>
                                <th class="py-3 text-center">Status</th>
                                <th class="py-3">Date</th>
                                <th class="py-3 text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var request in Model.Take(10))
                                {
                                    @* 🔥 التعديل هنا: جعل السطر بالكامل قابل للضغط 🔥 *@
                                    <tr class="clickable-task-row" data-url="@Url.Action("Details", "Requests", new { id = request.Id })" style="cursor: pointer;">
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle bg-soft-primary text-primary d-flex align-items-center justify-content-center me-3" style="width:40px; height:40px; font-weight: bold;">
                                                    @(request.Customer?.FullName?.Substring(0, 1) ?? "U")
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark">@request.Category?.Name</div>
                                                    <span class="text-muted small">Client: @request.Customer?.FullName</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge rounded-pill @(request.Status == "Completed" || request.Status == "Finished" ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning") px-3 py-2">
                                                @request.Status
                                            </span>
                                        </td>
                                        <td class="text-muted">@request.CreatedAt.ToString("MMM dd, yyyy")</td>

                                        @* 🔒 نمنع تفعيل ضغطة السطر عند الضغط على الأزرار 🔒 *@
                                        <td class="text-center" onclick="event.stopPropagation();">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a asp-controller="Requests" asp-action="Details" asp-route-id="@request.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                    Details
                                                </a>

                                                @if (request.Status == "Accepted")
                                                {
                                                    <form asp-controller="Requests" asp-action="CompleteRequest" method="post" style="display:inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@request.Id" />
                                                        <button type="submit" class="btn btn-sm btn-success rounded-pill px-3" onclick="return confirm('Mark this job as finished and collect your earnings (90%)?')">
                                                            <i class="fas fa-check me-1"></i> Finish
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">
                                        <i class="fas fa-folder-open fa-3x mb-3 d-block opacity-25"></i>
                                        No active tasks found in your record.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .bg-success-subtle {
        background-color: #e8f5e9;
        color: #2e7d32;
    }

    .bg-warning-subtle {
        background-color: #fff3e0;
        color: #ef6c00;
    }

    .bg-soft-primary {
        background-color: #e8eaf6;
    }

    .card {
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    /* تأثير تمرير الماوس على السطر */
    .clickable-task-row:hover {
        background-color: rgba(26, 35, 126, 0.04) !important;
        transition: all 0.2s ease-in-out;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            // كود الجافا سكريبت للانتقال السريع
            $(".clickable-task-row").click(function () {
                window.location = $(this).data("url");
            });
        });
    </script>
}