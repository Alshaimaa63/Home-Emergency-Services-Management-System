@model IEnumerable<HomeServices.Models.Request>
@{
    ViewData["Title"] = "My History";
}
<link rel="stylesheet" href="~/css/history.css" />

<div class="history-bg">
    <div class="container">
        <div class="mb-5">
            <h2 class="fw-bold" style="color: #1a237e;">My Work History</h2>
            <p class="text-muted">Review your accepted tasks and finalize active jobs.</p>
        </div>

        <div class="custom-table-container">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Service</th>
                        <th>Status</th>
                        <th>Schedule</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@item.Category.Name</div>
                                <div class="text-muted small">@item.Description</div>
                            </td>
                            <td>
                                <div class="badge-ui status-@item.Status.ToLower().Replace(" ", "")">
                                    <span class="status-dot"></span> @item.Status
                                </div>
                            </td>
                            <td>@item.PreferredSchedule</td>
                            <td class="text-end pe-4">
                                @if (item.Status == "Accepted")
                                {
                                    <form asp-action="CompleteRequest" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3">Mark Complete</button>
                                    </form>
                                }
                                <a asp-controller="Requests" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm rounded-pill">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>