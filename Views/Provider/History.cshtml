@model IEnumerable<HomeServices.Models.Request>
@{
    ViewData["Title"] = "My History";
}
<link rel="stylesheet" href="~/css/history.css" />

<div class="history-bg">
    <div class="container">
        <div class="mb-5">
            <h2 class="fw-bold" style="color: #1a237e;">My Work History</h2>
            <p class="text-muted">Review your accepted tasks and finalize active jobs.</p>
        </div>

        <div class="custom-table-container shadow-sm border rounded">
            <table class="table mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Service</th>
                        <th>Status</th>
                        <th>Price</th> <!-- العمود الجديد -->
                        <th>Schedule</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@item.Category?.Name</div>
                                <div class="text-muted small text-truncate" style="max-width: 200px;">@item.Description</div>
                            </td>
                            <td>
                                <div class="badge-ui status-@item.Status.ToLower().Replace(" ", "")">
                                    <span class="status-dot"></span> @item.Status
                                </div>
                            </td>
                            <!-- عرض السعر المتفق عليه -->
                            <td class="fw-bold text-dark">
                                @(item.FinalPrice.HasValue? item.FinalPrice.Value.ToString("C") : "N/A")
                            </td>
                            <td>@item.PreferredSchedule.ToString("g")</td>
                            <td class="text-end pe-4">
                                @if (item.Status == "Accepted")
                                {
                                    <form asp-action="CompleteRequest" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">Mark Complete</button>
                                    </form>
                                }
                                <a asp-controller="Requests" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm rounded-pill">Details</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-folder-open fa-3x mb-3 d-block opacity-25"></i>
                                No work history found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>