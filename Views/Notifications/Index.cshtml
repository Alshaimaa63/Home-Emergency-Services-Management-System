@model IEnumerable<HomeServices.Models.Notification>
@{
    ViewData["Title"] = "My Notifications";
}

<div class="container my-5">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-white py-3 border-bottom">
            <h4 class="mb-0 fw-bold" style="color: #1a237e;"><i class="fas fa-bell me-2"></i> Notifications</h4>
        </div>
        <div class="list-group list-group-flush">
            @if (!Model.Any())
            {
                <div class="p-5 text-center text-muted">
                    <i class="fas fa-comment-slash fa-3x mb-3 opacity-25"></i>
                    <p>No new updates for you yet.</p>
                </div>
            }
            @foreach (var item in Model)
            {
                <a href="@item.TargetUrl" class="list-group-item list-group-item-action py-3 @(item.IsRead ? "" : "bg-light border-start border-primary border-4")">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-dark">@item.Message</span>
                        <small class="text-muted">@item.CreatedAt.ToString("MMM dd, HH:mm")</small>
                    </div>
                </a>
            }
        </div>
    </div>
</div>